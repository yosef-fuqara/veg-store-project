NODE_ENV=development
PORT=5000
API_BASE_PATH=/api/v1

MONGO_URI=mongodb://127.0.0.1:27017/veg_store

JWT_ACCESS_SECRET=replace_with_strong_random_secret
JWT_REFRESH_SECRET=replace_with_different_strong_random_secret
# 15m is strict for shoppers (add-to-cart starts failing while the header still shows their name). Use 8h or 24h locally if you prefer.
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

CORS_ORIGIN_STORE=http://localhost:5173
CORS_ORIGIN_ADMIN=http://localhost:5174

# Storefront base URL for password-reset links in email (defaults to CORS_ORIGIN_STORE).
STOREFRONT_URL=http://localhost:5173
# Password reset token lifetime in milliseconds (default 30 minutes).
# PASSWORD_RESET_TTL_MS=1800000

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200

CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=veg-store

# Delivery areas and fees are defined in src/constants/delivery.js.
# Local village (Bu'eine Nujeidat): free over 100 ILS, otherwise 10 ILS.
# Other allowed areas: free over 200 ILS, otherwise 30 ILS.

# WhatsApp transactional messages — new order (admin) + order updates (customer).
# Same provider credentials are used for both; customer destination is the order phone.
# Idempotency for both email and WhatsApp is stored on order.emailNotifications (see wa_notify:* keys).
# When disabled or misconfigured, requests still succeed and a safe warning is logged.
WHATSAPP_NOTIFICATIONS_ENABLED=false
# Provider: "meta_cloud" | "twilio" | "log"
WHATSAPP_PROVIDER=
WHATSAPP_API_TOKEN=
# Required for meta_cloud
WHATSAPP_PHONE_NUMBER_ID=
# Required for twilio
WHATSAPP_TWILIO_ACCOUNT_SID=
WHATSAPP_TWILIO_FROM=
# International format, e.g. +972501234567
ADMIN_WHATSAPP_PHONE=
# Used to build admin links inside notifications, e.g. http://localhost:5174
ADMIN_BASE_URL=http://localhost:5174

PAYMENT_PROVIDER=placeholder
PAYMENT_API_KEY=provider_key_here
PAYMENT_WEBHOOK_SECRET=provider_webhook_secret_here
PAYMENT_CALLBACK_URL=http://localhost:5000/api/v1/payments/webhook
PAYMENT_SUCCESS_URL=http://localhost:5173/checkout/success
PAYMENT_CANCEL_URL=http://localhost:5173/checkout/cancel

# Transactional email (optional). If MAIL_HOST is unset, emails are skipped.
MAIL_HOST=
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=
MAIL_FROM=
# Bank transfer admin alert + optional operational mail
ADMIN_EMAIL=

# Bulk import (scripts/import-products.js) — optional
# IMPORT_API_BASE_URL=http://localhost:5000/api/v1
# IMPORT_ACCESS_TOKEN=
# IMPORT_ADMIN_EMAIL=
# IMPORT_ADMIN_PASSWORD=
# IMPORT_MINT_ADMIN_JWT=1
# IMPORT_LEMON_JUICE_SLUG=
# IMPORT_POM_JUICE_SLUG=
# IMPORT_DRY_RUN=1
